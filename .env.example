# =====================================================================
# terra-server 환경 변수 (template)
# 실제 값은 .env 로 복사 후 입력. .env 는 절대 커밋 금지.
# =====================================================================

# ---------- Supabase ----------
# 대시보드 > Settings > API 에서 복사.
# SERVICE_ROLE_KEY 는 RLS 바이패스 → 절대 클라이언트 노출 금지. .env 에만.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Publishable key (구 "anon public") — 클라이언트(웹/모바일) 노출 OK. RLS 가 보호.
# Supabase 대시보드 > Settings > API > "Publishable keys" 섹션
# (구 UI 라면 "anon public" 줄). service_role / Secret keys 와 혼동 금지.
# 백엔드는 직접 안 쓰지만 GET /web-config 으로 정적 웹페이지에 내려보냄.
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Dev 모드 전용 user_id (auth.users.id 의 UUID). Stage 초반 로컬 테스트용.
DEV_USER_ID=00000000-0000-0000-0000-000000000000

# ---------- 인증 모드 ----------
# dev: JWT 검증 스킵, DEV_USER_ID 그대로 사용 (로컬/pytest)
# prod: Authorization: Bearer <JWT> 필수, Supabase access_token 검증
AUTH_MODE=dev

# AUTH_MODE=prod 일 때 필수
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# ---------- MQTT 브로커 (Mosquitto) ----------
# 브리지가 connect 할 broker. Lightsail 내부 / 외부 둘 다 가능.
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=8883
MQTT_USE_TLS=true
# Let's Encrypt 인증서 사용 시 시스템 CA 사용 → 빈 값 유지.
# 자체 서명 인증서면 CA 파일 절대경로 지정.
MQTT_CA_CERT_PATH=

# 브리지 전용 MQTT 계정 (Mosquitto password file 에 별도 등록)
# 디바이스 계정과 분리. 브리지는 모든 토픽 publish/subscribe 권한.
MQTT_BRIDGE_USERNAME=terra-bridge
MQTT_BRIDGE_PASSWORD=change-me-strong-password

# ---------- API 서버 ----------
# CORS 허용 origin (콤마 구분). 빈 값이면 "*" (개발용).
APP_ORIGINS=http://localhost:3000,https://app.example.com

# OpenAPI 문서 (/docs, /redoc, /openapi.json) HTTP Basic Auth.
# 둘 중 하나라도 빈 값이면 모든 요청이 401 → 사실상 docs 차단.
# 강력한 비번 권장: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
DOCS_BASIC_USER=terra
DOCS_BASIC_PASS=change-me-docs-password

# ---------- Cloudflare R2 (영상 클립 저장, Stage F) ----------
# ESP32-CAM 이 모션 감지 → AVI 영상을 R2 에 직접 PUT (presigned URL 사용).
# 메타만 Supabase motion_clips 테이블에 저장.
# - R2_ACCOUNT_ID: 대시보드 우측 상단 Account ID (32자 hex)
# - R2_ENDPOINT: https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: R2 > Manage R2 API Tokens (Object R/W)
# - R2_BUCKET: 버킷 이름 (대시보드에서 미리 생성)
# - R2_PUBLIC_BASE_URL: 옵션. 공개 도메인 연결 시 (없으면 presigned GET URL 만 사용)
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=terra-clips
R2_PUBLIC_BASE_URL=

# ---------- 알림 (Stage E 이후) ----------
# FCM 서비스 계정 키 경로 등 추후 추가
# FCM_CREDENTIALS_PATH=
